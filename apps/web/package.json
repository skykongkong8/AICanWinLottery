{
  "name": "@lotto/web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "pnpm run typecheck:pkg",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:pkg",
    "typecheck:pkg": "tsc -p tsconfig.json --noEmit",
    "test:pkg": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3",
    "typescript": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@lotto/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "vitest": "^2.1.8"
  }
}
